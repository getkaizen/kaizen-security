{
  "name": "kaizen-security",
  "version": "0.2.0",
  "description": "Runtime security for AI agents. Inspect every action, learn normal behaviour, flag what falls outside it, and block known-bad.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vercel": {
      "types": "./dist/integrations/vercel.d.ts",
      "import": "./dist/integrations/vercel.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run"
  },
  "keywords": [
    "ai",
    "agents",
    "security",
    "mcp",
    "guardrails"
  ],
  "license": "Apache-2.0",
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
